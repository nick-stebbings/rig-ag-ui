# Server Configuration
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# Rig API Backend
# Configure the middleware to point at the Rig backend root URL.
# The built-in agent appends /sessions, /sessions/:id/messages, and
# /sessions/:id/interrupt internally.
#
# Backend that already includes the Rig path in the base URL:
#   RIG_API_BASE_URL=http://localhost:8080/internal/rig
#   RIG_API_PATH=
#
# Standalone backend with Rig routes behind a shared prefix:
#   RIG_API_BASE_URL=http://localhost:8080
#   RIG_API_PATH=/internal/rig
RIG_API_BASE_URL=http://localhost:8080
RIG_API_PATH=/internal/rig

# Authentication
# This API key must match what clients send in the x-api-key header.
AGUI_API_KEY=development-key

# Agent bootstrap for /copilotkit/info
# Option 1: static registry
# AGENT_REGISTRY={"my-agent":{"description":"My custom agent"}}
#
# Option 2: custom discovery endpoint, cached for 60 seconds.
# Supports {"tools":[{"name":"tool-name","bundle_id":"bundle-id","description":"..."}]}
# or {"agents":{"my-agent":{"description":"..."}}}
# AGENT_DISCOVERY_URL=http://localhost:8080/api/v1/bundle-agents
# AGENT_DISCOVERY_HEADERS={"x-service-key":"replace-me"}

# CORS Configuration
# For development, use "*" or specific origins.
# Production should restrict to known origins
ALLOWED_ORIGINS=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # Max requests per window

# OpenTelemetry Configuration
# Service name for trace identification
OTEL_SERVICE_NAME=ag-ui-middleware
# OTLP endpoint for trace export (leave empty to disable export)
# Local Jaeger: http://localhost:4318
# Grafana Cloud: https://otlp-gateway-prod-<region>.grafana.net/otlp
OTEL_EXPORTER_OTLP_ENDPOINT=
# OTLP headers for authentication (Grafana Cloud requires this)
# Format: "Authorization=Basic <base64-encoded-credentials>"
OTEL_EXPORTER_OTLP_HEADERS=
# Enable OTEL debug logging (optional)
OTEL_DEBUG=false
